# Copy to .env (or set these in your host's dashboard) and fill in.

# Password for the admin home + dashboard (HTTP Basic Auth; username is ignored).
# If unset, a random one is printed to the console at startup.
ADMIN_KEY=change-me-to-a-long-random-string

# Port to listen on (most hosts set this automatically).
PORT=3000

# Where the SQLite database file lives.
DATABASE_PATH=./data/visits.db
